<article class="post post-layout">
  <%
    const wordCount = strip_html(page.content || '').replace(/\s+/g, '').length;
    const readingMinutes = Math.max(1, Math.ceil(wordCount / 500));
  %>
  <header class="post-header">
    <h1><%= page.title %></h1>
    <div class="post-meta-line">
      <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
      <span><%= readingMinutes %> 分钟阅读</span>
      <span><%= wordCount %> 字</span>
      <% if (page.updated && date(page.updated, 'YYYY-MM-DD') !== date(page.date, 'YYYY-MM-DD')) { %>
        <span>更新于 <time datetime="<%= date_xml(page.updated) %>"><%= date(page.updated, 'YYYY-MM-DD') %></time></span>
      <% } %>
    </div>
  </header>
  <% if (page.cover) { %>
    <img class="post-hero" src="<%= url_for(page.cover) %>" alt="" loading="eager">
  <% } %>
  <% if (page.tags && page.tags.length) { %>
    <div class="post-meta">
      <% page.tags.each(function(tag){ %>
        <a class="tag" href="<%= url_for(tag.path) %>">
          <span class="tag-name"><%= tag.name %></span>
        </a>
      <% }) %>
    </div>
  <% } %>
  <div class="post-actions" aria-label="文章操作">
    <button class="text-action" type="button" data-copy-link data-copy-text="复制链接" data-copied-text="已复制">复制链接</button>
    <a class="text-action" href="<%= url_for('/archives/') %>">查看归档</a>
  </div>
  <div class="post-body">
    <div class="post-content">
      <%- page.content %>
    </div>
    <% if (toc(page.content)) { %>
      <aside class="post-toc" aria-label="文章目录">
        <h3>目录</h3>
        <div class="toc-inner">
          <%- toc(page.content) %>
        </div>
      </aside>
    <% } %>
  </div>
  <footer class="post-end">
    <div class="post-end-card">
      <h2>读完这篇</h2>
      <dl class="post-facts">
        <div>
          <dt>字数</dt>
          <dd><%= wordCount %></dd>
        </div>
        <div>
          <dt>阅读</dt>
          <dd><%= readingMinutes %> 分钟</dd>
        </div>
        <% if (page.categories && page.categories.length) { %>
          <div>
            <dt>分类</dt>
            <dd>
              <% page.categories.each(function(cat, index){ %>
                <a href="<%= url_for(cat.path) %>"><%= cat.name %></a><%= index < page.categories.length - 1 ? '、' : '' %>
              <% }) %>
            </dd>
          </div>
        <% } %>
      </dl>
      <div class="post-end-actions">
        <a class="text-action" href="<%= url_for('/') %>">回到首页</a>
        <a class="text-action" href="<%= url_for('/tags/') %>">浏览标签</a>
      </div>
    </div>
  </footer>
  <nav class="post-nav" aria-label="文章翻页">
    <% if (page.prev) { %>
      <a href="<%= url_for(page.prev.path) %>">上一篇：<%= page.prev.title %></a>
    <% } %>
    <% if (page.next) { %>
      <a href="<%= url_for(page.next.path) %>">下一篇：<%= page.next.title %></a>
    <% } %>
  </nav>
</article>
