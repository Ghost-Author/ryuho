<%
  const tagList = [];
  const categoryList = [];
  site.tags.each(function(tag) { tagList.push(tag); });
  site.categories.each(function(cat) { categoryList.push(cat); });
  const preferredNames = ['AI 工程', '大模型应用', 'RAG', '智能体', '评测', 'Prompt', '工程实践', '系统设计', '效率工具', 'Hexo', 'CI/CD', 'SEO'];
  function sortByProductPriority(a, b) {
    const aIndex = preferredNames.indexOf(a.name);
    const bIndex = preferredNames.indexOf(b.name);
    if (aIndex !== -1 || bIndex !== -1) {
      if (aIndex === -1) return 1;
      if (bIndex === -1) return -1;
      return aIndex - bIndex;
    }
    return b.length - a.length;
  }
  tagList.sort(sortByProductPriority);
  categoryList.sort(sortByProductPriority);

  const orderedPosts = [];
  site.posts.sort('date', -1).each(function(post) { orderedPosts.push(post); });
  const latestPost = orderedPosts[0] || null;
  const latestExcerpt = latestPost ? (latestPost.description || strip_html(latestPost.excerpt || latestPost.content || '').replace(/\s+/g, ' ').trim()) : '';
  const latestReadingMinutes = latestPost ? Math.max(1, Math.ceil(strip_html(latestPost.content || '').length / 500)) : 0;
%>

<section class="hero">
  <div class="hero-card">
    <p class="hero-kicker">IT 个人博客 · AI 工程 · 系统思考</p>
    <h1><%= config.title %></h1>
    <% if (config.subtitle) { %>
      <p class="subtitle"><%= config.subtitle %></p>
    <% } %>
    <div class="hero-actions">
      <a class="btn primary" href="<%= latestPost ? url_for(latestPost.path) : url_for('/archives/') %>">阅读最新文章</a>
      <a class="btn ghost" href="<%= url_for('/categories/') %>">浏览技术分类</a>
    </div>
    <div class="hero-search">
      <label class="search-label" for="home-search">搜索文章</label>
      <input id="home-search" type="search" placeholder="搜索标题、摘要或标签..." data-search-input autocomplete="off">
      <a class="rss-link" href="<%= url_for('/atom.xml') %>" target="_blank" rel="noopener">订阅 RSS</a>
    </div>
  </div>
</section>

<section class="latest-spotlight" aria-labelledby="latest-title">
  <div class="section-title">
    <h2 id="latest-title">刚刚更新</h2>
    <a href="<%= url_for('/archives/') %>">完整归档</a>
  </div>
  <% if (latestPost) { %>
    <article class="spotlight-card">
      <div class="spotlight-main">
        <div class="spotlight-meta">
          <time datetime="<%= date_xml(latestPost.date) %>"><%= date(latestPost.date, 'YYYY-MM-DD') %></time>
          <span><%= latestReadingMinutes %> 分钟阅读</span>
        </div>
        <h3><a href="<%= url_for(latestPost.path) %>"><%= latestPost.title %></a></h3>
        <% if (latestExcerpt) { %>
          <p><%= latestExcerpt.slice(0, 128) %></p>
        <% } %>
        <% if (latestPost.tags && latestPost.tags.length) { %>
          <div class="mini-tags" aria-label="最新文章标签">
            <% latestPost.tags.each(function(tag){ %>
              <a href="<%= url_for(tag.path) %>">#<%= tag.name %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
      <a class="spotlight-action" href="<%= url_for(latestPost.path) %>">继续阅读</a>
    </article>
  <% } else { %>
    <p class="empty-state">第一篇文章正在路上。</p>
  <% } %>
</section>

<section class="series-band" aria-labelledby="series-title">
  <div>
    <p class="series-kicker">专题路径</p>
    <h2 id="series-title">AI 工程上线路径</h2>
    <p>从评测集、RAG、智能体边界到上线后的可观测性，把 AI 能力整理成可验证、可维护的工程流程。</p>
  </div>
  <a class="btn primary" href="<%= url_for('/series/ai-engineering/') %>">开始系统阅读</a>
</section>

<section class="profile-grid">
  <div class="profile-card">
    <div class="avatar">
      <% if (theme.avatar_url) { %>
        <img src="<%= url_for(theme.avatar_url) %>" alt="avatar" width="64" height="64" decoding="async">
      <% } %>
    </div>
    <div>
      <h2><%= theme.profile_title || config.author %></h2>
      <p class="subtitle"><%= theme.profile_subtitle || config.description %></p>
      <div class="chip-row">
        <% (theme.profile_chips || []).forEach(function(chip){ %>
          <span class="chip"><%= chip %></span>
        <% }) %>
      </div>
    </div>
  </div>
  <div class="stats-card">
    <div class="stat">
      <span class="stat-label">文章</span>
      <span class="stat-value"><%= site.posts.length %></span>
    </div>
    <div class="stat">
      <span class="stat-label">标签</span>
      <span class="stat-value"><%= site.tags.length %></span>
    </div>
    <div class="stat">
      <span class="stat-label">分类</span>
      <span class="stat-value"><%= site.categories.length %></span>
    </div>
  </div>
</section>

<section class="discover">
  <div class="section-title">
    <h2>技术索引</h2>
    <a href="<%= url_for('/tags/') %>">所有标签</a>
  </div>
  <div class="discover-grid">
    <article class="discover-panel">
      <h3>热门标签</h3>
      <% if (tagList.length) { %>
        <div class="compact-links">
          <% tagList.slice(0, 8).forEach(function(tag) { %>
            <a href="<%= url_for(tag.path) %>">
              <span>#<%= tag.name %></span>
              <strong><%= tag.length %></strong>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <p class="compact-note">还没有标签。</p>
      <% } %>
    </article>
    <article class="discover-panel">
      <h3>分类导航</h3>
      <% if (categoryList.length) { %>
        <div class="compact-links">
          <% categoryList.slice(0, 8).forEach(function(cat) { %>
            <a href="<%= url_for(cat.path) %>">
              <span><%= cat.name %></span>
              <strong><%= cat.length %></strong>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <p class="compact-note">还没有分类。</p>
      <% } %>
    </article>
    <article class="discover-panel latest-panel">
      <h3>最近更新</h3>
      <% if (latestPost) { %>
        <a class="latest-link" href="<%= url_for(latestPost.path) %>">
          <span><%= latestPost.title %></span>
          <time datetime="<%= date_xml(latestPost.date) %>"><%= date(latestPost.date, 'YYYY-MM-DD') %></time>
        </a>
      <% } else { %>
        <p class="compact-note">第一篇文章正在路上。</p>
      <% } %>
    </article>
  </div>
</section>

<section class="mood-links">
  <div class="mood-card">
    <h3>当前关注</h3>
    <p><%= theme.mood || '今日心情：一切都刚刚好。' %></p>
  </div>
  <div class="photo-card">
    <% if (theme.hero_image) { %>
      <img src="<%= url_for(theme.hero_image) %>" alt="hero" width="1920" height="1080" loading="lazy" decoding="async">
    <% } %>
    <div class="photo-caption"><%= theme.quote || '把温柔留给生活，把灵感留给自己。' %></div>
  </div>
  <div class="links-card">
    <h3>站点入口</h3>
    <div class="links-grid">
      <% (theme.links || []).forEach(function(link){ %>
        <a class="link-pill" href="<%= link.url %>" target="_blank" rel="noopener"><%= link.name %></a>
      <% }) %>
    </div>
  </div>
</section>

<% if (theme.focus_areas && theme.focus_areas.length) { %>
  <section class="focus-areas">
    <div class="section-title">
      <h2>写作方向</h2>
      <a href="<%= url_for('/categories/') %>">查看分类</a>
    </div>
    <div class="focus-grid">
      <% theme.focus_areas.forEach(function(area){ %>
        <article class="focus-card">
          <h3><%= area.title %></h3>
          <p><%= area.description %></p>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="subscribe-band">
  <div>
    <h2>想持续收到更新？</h2>
    <p>可以订阅 RSS，也可以从关于页找到联系方式。这里会持续沉淀 AI 工程、技术复盘和个人效率工具。</p>
  </div>
  <div class="subscribe-actions">
    <a class="btn primary" href="<%= url_for('/atom.xml') %>" target="_blank" rel="noopener">订阅 RSS</a>
    <a class="btn ghost" href="<%= url_for('/about/') %>">联系作者</a>
  </div>
</section>

<section class="featured">
  <div class="section-title">
    <h2>推荐阅读</h2>
    <a href="<%= url_for('/archives/') %>">查看全部</a>
  </div>
  <div class="featured-grid">
    <% 
      const favoritesTag = theme.favorites_tag || '';
      const candidates = favoritesTag ? site.posts.filter(function(p){ 
        return p.tags && p.tags.find(function(t){ return t.name === favoritesTag; });
      }) : page.posts;
      const pick = (candidates.length ? candidates : page.posts).slice(0, 3);
    %>
    <% pick.forEach(function(post){ %>
      <article class="featured-card">
        <a href="<%= url_for(post.path) %>">
          <h3><%= post.title %></h3>
          <p class="featured-excerpt"><%= (post.description || (post.excerpt ? strip_html(post.excerpt) : '点进来看看这篇技术记录。')).slice(0, 80) %></p>
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
        </a>
      </article>
    <% }) %>
  </div>
</section>

<section class="timeline">
  <div class="section-title">
    <h2>时间线</h2>
    <a href="<%= url_for('/archives/') %>">完整归档</a>
  </div>
  <div class="timeline-list">
    <% if (page.posts.length) { %>
      <% page.posts.slice(0, 5).forEach(function(post){ %>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
          <a href="<%= url_for(post.path) %>"><%= post.title %></a>
        </div>
      </div>
      <% }) %>
    <% } else { %>
      <p class="empty-state">还没有文章，第一篇正在路上。</p>
    <% } %>
  </div>
</section>

<div class="section-title">
  <h2>全部文章</h2>
  <span class="result-count" data-search-count><%= page.posts.length %> 篇</span>
</div>
<ul class="post-list" data-post-list>
  <% page.posts.each(function(post){ %>
    <%
      const postExcerpt = post.description || strip_html(post.excerpt || post.content || '').replace(/\s+/g, ' ').trim();
      const postTags = post.tags ? post.tags.map(function(tag){ return tag.name; }).join(' ') : '';
      const readingMinutes = Math.max(1, Math.ceil(strip_html(post.content || '').length / 500));
    %>
    <li class="post-item rich-post-item" data-post-item data-title="<%= post.title %>" data-excerpt="<%= postExcerpt %>" data-tags="<%= postTags %>">
      <div class="post-main">
        <% if (post.cover) { %>
          <img class="post-cover" src="<%= url_for(post.cover) %>" alt="" width="64" height="48" loading="lazy" decoding="async">
        <% } %>
        <div>
          <a class="post-link" href="<%= url_for(post.path) %>"><%= post.title %></a>
          <% if (postExcerpt) { %>
            <p class="post-excerpt"><%= postExcerpt.slice(0, 96) %></p>
          <% } %>
          <% if (post.tags && post.tags.length) { %>
            <div class="mini-tags" aria-label="文章标签">
              <% post.tags.each(function(tag){ %>
                <a href="<%= url_for(tag.path) %>">#<%= tag.name %></a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
      <div class="post-side">
        <time class="post-date" datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
        <span class="reading-time"><%= readingMinutes %> 分钟</span>
      </div>
    </li>
  <% }) %>
</ul>
<p class="empty-state search-empty" data-search-empty hidden>没有找到匹配的文章，换个关键词试试。</p>

<% if (page.total > page.current) { %>
  <nav class="pagination">
    <a class="next" href="<%= url_for(page.next_link) %>">下一页</a>
  </nav>
<% } %>
