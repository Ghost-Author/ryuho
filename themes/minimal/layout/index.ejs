<section class="hero">
  <div class="hero-card">
    <p class="hero-kicker">欢迎来到我的小宇宙</p>
    <h1><%= config.title %></h1>
    <% if (config.subtitle) { %>
      <p class="subtitle"><%= config.subtitle %></p>
    <% } %>
    <div class="hero-actions">
      <a class="btn primary" href="<%= url_for('/archives/') %>">最近更新</a>
      <a class="btn ghost" href="<%= url_for('/about/') %>">认识我</a>
    </div>
    <div class="hero-search">
      <label class="search-label" for="home-search">搜索文章</label>
      <input id="home-search" type="search" placeholder="搜索标题、摘要或标签..." data-search-input autocomplete="off">
      <a class="rss-link" href="<%= url_for('/atom.xml') %>" target="_blank" rel="noopener">订阅 RSS</a>
    </div>
  </div>
</section>

<section class="profile-grid">
  <div class="profile-card">
    <div class="avatar">
      <% if (theme.avatar_url) { %>
        <img src="<%= url_for(theme.avatar_url) %>" alt="avatar">
      <% } %>
    </div>
    <div>
      <h2><%= config.author %></h2>
      <p class="subtitle">记录生活与灵感的小确幸</p>
      <div class="chip-row">
        <span class="chip">可爱主义</span>
        <span class="chip">生活随笔</span>
        <span class="chip">阅读笔记</span>
      </div>
    </div>
  </div>
  <div class="stats-card">
    <div class="stat">
      <span class="stat-label">文章</span>
      <span class="stat-value"><%= site.posts.length %></span>
    </div>
    <div class="stat">
      <span class="stat-label">标签</span>
      <span class="stat-value"><%= site.tags.length %></span>
    </div>
    <div class="stat">
      <span class="stat-label">分类</span>
      <span class="stat-value"><%= site.categories.length %></span>
    </div>
  </div>
</section>

<section class="discover">
  <div class="section-title">
    <h2>探索小站</h2>
    <a href="<%= url_for('/tags/') %>">所有标签</a>
  </div>
  <%
    const tagList = [];
    const categoryList = [];
    site.tags.each(function(tag) { tagList.push(tag); });
    site.categories.each(function(cat) { categoryList.push(cat); });
    tagList.sort(function(a, b) { return b.length - a.length; });
    categoryList.sort(function(a, b) { return b.length - a.length; });
    const latestPost = page.posts.length ? page.posts.slice(0, 1)[0] : null;
  %>
  <div class="discover-grid">
    <article class="discover-panel">
      <h3>热门标签</h3>
      <% if (tagList.length) { %>
        <div class="compact-links">
          <% tagList.slice(0, 8).forEach(function(tag) { %>
            <a href="<%= url_for(tag.path) %>">
              <span>#<%= tag.name %></span>
              <strong><%= tag.length %></strong>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <p class="compact-note">还没有标签。</p>
      <% } %>
    </article>
    <article class="discover-panel">
      <h3>分类导航</h3>
      <% if (categoryList.length) { %>
        <div class="compact-links">
          <% categoryList.slice(0, 8).forEach(function(cat) { %>
            <a href="<%= url_for(cat.path) %>">
              <span><%= cat.name %></span>
              <strong><%= cat.length %></strong>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <p class="compact-note">还没有分类。</p>
      <% } %>
    </article>
    <article class="discover-panel latest-panel">
      <h3>最近更新</h3>
      <% if (latestPost) { %>
        <a class="latest-link" href="<%= url_for(latestPost.path) %>">
          <span><%= latestPost.title %></span>
          <time datetime="<%= date_xml(latestPost.date) %>"><%= date(latestPost.date, 'YYYY-MM-DD') %></time>
        </a>
      <% } else { %>
        <p class="compact-note">第一篇文章正在路上。</p>
      <% } %>
    </article>
  </div>
</section>

<section class="mood-links">
  <div class="mood-card">
    <h3>今日一句</h3>
    <p><%= theme.mood || '今日心情：一切都刚刚好。' %></p>
  </div>
  <div class="photo-card">
    <% if (theme.hero_image) { %>
      <img src="<%= url_for(theme.hero_image) %>" alt="hero" loading="lazy">
    <% } %>
    <div class="photo-caption"><%= theme.quote || '把温柔留给生活，把灵感留给自己。' %></div>
  </div>
  <div class="links-card">
    <h3>友情链接</h3>
    <div class="links-grid">
      <% (theme.links || []).forEach(function(link){ %>
        <a class="link-pill" href="<%= link.url %>" target="_blank" rel="noopener"><%= link.name %></a>
      <% }) %>
    </div>
  </div>
</section>

<section class="featured">
  <div class="section-title">
    <h2>精选小卡片</h2>
    <a href="<%= url_for('/archives/') %>">查看全部</a>
  </div>
  <div class="featured-grid">
    <% 
      const favoritesTag = theme.favorites_tag || '';
      const candidates = favoritesTag ? site.posts.filter(function(p){ 
        return p.tags && p.tags.find(function(t){ return t.name === favoritesTag; });
      }) : page.posts;
      const pick = (candidates.length ? candidates : page.posts).slice(0, 3);
    %>
    <% pick.forEach(function(post){ %>
      <article class="featured-card">
        <a href="<%= url_for(post.path) %>">
          <h3><%= post.title %></h3>
          <p class="featured-excerpt"><%= post.excerpt ? strip_html(post.excerpt).slice(0, 80) : '点进来看看这篇小故事～' %></p>
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
        </a>
      </article>
    <% }) %>
  </div>
</section>

<section class="timeline">
  <div class="section-title">
    <h2>时间线</h2>
    <a href="<%= url_for('/archives/') %>">完整归档</a>
  </div>
  <div class="timeline-list">
    <% if (page.posts.length) { %>
      <% page.posts.slice(0, 5).forEach(function(post){ %>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
          <a href="<%= url_for(post.path) %>"><%= post.title %></a>
        </div>
      </div>
      <% }) %>
    <% } else { %>
      <p class="empty-state">还没有文章，第一篇正在路上。</p>
    <% } %>
  </div>
</section>

<div class="section-title">
  <h2>全部文章</h2>
  <span class="result-count" data-search-count><%= page.posts.length %> 篇</span>
</div>
<ul class="post-list" data-post-list>
  <% page.posts.each(function(post){ %>
    <%
      const postExcerpt = strip_html(post.excerpt || post.content || '').replace(/\s+/g, ' ').trim();
      const postTags = post.tags ? post.tags.map(function(tag){ return tag.name; }).join(' ') : '';
      const readingMinutes = Math.max(1, Math.ceil(strip_html(post.content || '').length / 500));
    %>
    <li class="post-item rich-post-item" data-post-item data-title="<%= post.title %>" data-excerpt="<%= postExcerpt %>" data-tags="<%= postTags %>">
      <div class="post-main">
        <% if (post.cover) { %>
          <img class="post-cover" src="<%= url_for(post.cover) %>" alt="" loading="lazy">
        <% } %>
        <div>
          <a class="post-link" href="<%= url_for(post.path) %>"><%= post.title %></a>
          <% if (postExcerpt) { %>
            <p class="post-excerpt"><%= postExcerpt.slice(0, 96) %></p>
          <% } %>
          <% if (post.tags && post.tags.length) { %>
            <div class="mini-tags" aria-label="文章标签">
              <% post.tags.each(function(tag){ %>
                <a href="<%= url_for(tag.path) %>">#<%= tag.name %></a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
      <div class="post-side">
        <time class="post-date" datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
        <span class="reading-time"><%= readingMinutes %> 分钟</span>
      </div>
    </li>
  <% }) %>
</ul>
<p class="empty-state search-empty" data-search-empty hidden>没有找到匹配的文章，换个关键词试试。</p>

<% if (page.total > page.current) { %>
  <nav class="pagination">
    <a class="next" href="<%= url_for(page.next_link) %>">下一页</a>
  </nav>
<% } %>
