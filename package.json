{
  "name": "ryuho",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "build:github": "hexo generate && npm run optimize:images",
    "clean": "hexo clean",
    "audit": "node tools/audit-site.js",
    "check": "npm run clean && npm run build:github && npm run audit",
    "check:vercel": "npm run build:vercel",
    "build:vercel": "hexo clean && hexo generate --config _config.yml,_config.vercel.yml && npm run optimize:images && npm run audit",
    "optimize:images": "node tools/image-optimize.js",
    "deploy": "hexo deploy",
    "new": "hexo new post",
    "daily": "node tools/daily.js",
    "start": "hexo server",
    "server": "hexo server"
  },
  "dependencies": {
    "hexo": "^7.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^2.2.0",
    "hexo-generator-index": "^3.0.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.0",
    "hexo-server": "^3.0.0",
    "lunr": "^2.3.9",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "hexo-cli": "^4.3.2"
  },
  "hexo": {
    "version": "7.3.0"
  }
}
